            "arn": "arn:aws:states:us-east-2:105299591393:stateMachine:async-task-processor-dev-task-workflow",
            "creation_date": "2026-04-13T09:06:45Z",
            "definition": "{\"Comment\":\"Task processing workflow: validate -\\u003e process task -\\u003e notify\",\"StartAt\":\"ValidateTask\",\"States\":{\"FailTask\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"TaskFailed\",\"ResultPath\":\"$.error\"}],\"Next\":\"TaskFailed\",\"Resource\":\"arn:aws:lambda:us-east-2:105299591393:function:async-task-processor-dev-fail-task\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"Lambda.ServiceException\",\"Lambda.AWSLambdaException\",\"Lambda.SdkClientException\",\"Lambda.TooManyRequestsException\"],\"IntervalSeconds\":2,\"JitterStrategy\":\"FULL\",\"MaxAttempts\":3}],\"Type\":\"Task\"},\"ProcessTask\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"FailTask\",\"ResultPath\":\"$.error\"}],\"Next\":\"TaskSucceeded\",\"Resource\":\"arn:aws:lambda:us-east-2:105299591393:function:async-task-processor-dev-process-task\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"States.ALL\"],\"IntervalSeconds\":2,\"JitterStrategy\":\"FULL\",\"MaxAttempts\":3}],\"Type\":\"Task\"},\"TaskFailed\":{\"Cause\":\"Task failed — check $.error in the execution event for details\",\"Error\":\"TaskProcessingFailed\",\"Type\":\"Fail\"},\"TaskSucceeded\":{\"Type\":\"Succeed\"},\"ValidateTask\":{\"Catch\":[{\"ErrorEquals\":[\"States.ALL\"],\"Next\":\"TaskFailed\",\"ResultPath\":\"$.error\"}],\"Next\":\"ProcessTask\",\"Resource\":\"arn:aws:lambda:us-east-2:105299591393:function:async-task-processor-dev-validate-task\",\"Retry\":[{\"BackoffRate\":2,\"ErrorEquals\":[\"Lambda.ServiceException\",\"Lambda.AWSLambdaException\",\"Lambda.SdkClientException\",\"Lambda.TooManyRequestsException\"],\"IntervalSeconds\":2,\"JitterStrategy\":\"FULL\",\"MaxAttempts\":3}],\"Type\":\"Task\"}}}",
