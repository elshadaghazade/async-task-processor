    "http_post_task": {
      "value": "curl -X POST https://84g06eird9.execute-api.us-east-2.amazonaws.com//tasks \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"taskId\": \"http-task-1\",\n    \"payload\": { \"dummy\": \"payload\" }\n  }'\n",
      "type": "string"
    },
