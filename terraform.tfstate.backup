      "value": "aws dynamodb get-item \\\n  --table-name async-task-processor-dev-tasks \\\n  --region us-east-2 \\\n  --key '{\"pk\": {\"S\": \"TASK#task-1\"}, \"sk\": {\"S\": \"DETAIL\"}}'\n",
